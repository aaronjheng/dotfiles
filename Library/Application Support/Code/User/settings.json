{
	"workbench.activityBar.visible": false,
	"workbench.colorTheme": "Spacegray Ocean Dark",
	"workbench.editor.showIcons": false,
	"workbench.iconTheme": null,
	"workbench.startupEditor": "newUntitledFile",
	"workbench.statusBar.feedback.visible": false,
	"workbench.settings.editor": "json",
	"workbench.colorCustomizations": {
		"focusBorder": "#232830",
		"badge.background": "#1c1f26",
		"badge.foreground": "#7f8f9b",
		"editorGroupHeader.tabsBackground": "#232830",
		"editorLineNumber.foreground": "#65737e",
		"editorGroup.border": "#232830",
		"foreground": "#7f8f9b",
		"statusBar.noFolderBackground": "#1c1f26",
		"tab.inactiveBackground": "#232830",
		"tab.inactiveForeground": "#7f8f9b"
	},
	"window.titleBarStyle": "custom",
	"window.zoomLevel": 0,
	"editor.fontFamily": "'Lucida Console', Menlo, Monaco, 'Courier New', monospace",
	"editor.fontSize": 14,
	"editor.lineHeight": 16,
	"editor.renderIndentGuides": false,
	"editor.scrollBeyondLastLine": false,
	"editor.tabSize": 4,
	"editor.detectIndentation": true,
	"editor.insertSpaces": false,
	"editor.overviewRulerBorder": false,
	"editor.minimap.enabled": false,
	"explorer.confirmDelete": false,
	"explorer.openEditors.visible": 0,
	"extensions.showRecommendationsOnlyOnDemand": true,
	"extensions.autoUpdate": false,
	"extensions.ignoreRecommendations": true,
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/*.pyc": true,
		"**/__pycache__/": true
	},
	"git.enabled": false,
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.fontFamily": "'Lucida Console', Menlo, Monaco, 'Courier New', monospace",
	"terminal.external.osxExec": "iTerm.app",
	"telemetry.enableTelemetry": false,
	"telemetry.enableCrashReporter": false,
	"typescript.check.npmIsInstalled": false,
	"update.mode": "none",
	"[python]": {
		"editor.insertSpaces": true
	},
	"[rust]": {
		"editor.formatOnSave": true
	},
	// Extension specific
	"go.coverOnSave": false,
	"go.lintOnSave": "off",
	"go.vetOnSave": "off",
	"go.useLanguageServer": true,
	"python.pythonPath": "python",
	"python.formatting.provider": "black",
	"python.linting.pylintEnabled": false
}