{
	"workbench.activityBar.visible": false,
	"workbench.editor.showIcons": false,
	"workbench.iconTheme": null,
	"workbench.startupEditor": "newUntitledFile",
	"workbench.settings.editor": "json",
	"workbench.colorTheme": "Spacegray Ocean Dark",
	"workbench.colorCustomizations": {
		"activityBar.background": "#1c1f26",
		"badge.background": "#1c1f26",
		"badge.foreground": "#7f8f9b",
		"dropdown.background": "#1c1f26",
		"editor.lineHighlightBackground": "#65737e30",
		"editor.background": "#2b303b",
		"editor.selectionBackground": "#4f5b66",
		"editor.foreground": "#c0c5ce",
		"editorCursor.foreground": "#c0c5ce",
		"editorGroupHeader.tabsBackground": "#232830",
		"editorGroup.border": "#232830",
		"editorGroup.dropBackground": "#1c1f26",
		"editorHoverWidget.background": "#232830",
		"editorHoverWidget.border": "#343d46",
		"editorIndentGuide.background": "#3b5364",
		"editorLineNumber.foreground": "#65737e",
		"editorWhitespace.foreground": "#65737e",
		"editorWidget.background": "#232830",
		"focusBorder": "#2b303b",
		"foreground": "#7f8f9b",
		"input.background": "#1c1f26",
		"list.activeSelectionBackground": "#343d46",
		"list.activeSelectionForeground": "#c0c5ce",
		"list.focusBackground": "#343d46",
		"list.hoverBackground": "#343d46",
		"list.hoverForeground": "#c0c5ce",
		"list.inactiveSelectionBackground": "#343d46",
		"menu.foreground": "#7f8f9b",
		"menu.selectionForeground": "#c0c5ce",
		"tab.border": "#232830",
		"tab.inactiveBackground": "#232830",
		"tab.inactiveForeground": "#7f8f9b",
		"titleBar.activeBackground": "#1c1f26",
		"titleBar.activeForeground": "#7f8f9b",
		"titleBar.inactiveBackground": "#1c1f26",
		"sideBar.background": "#232830",
		"sideBarSectionHeader.background": "#1c1f26",
		"statusBar.background": "#1c1f26",
		"statusBar.debuggingBackground": "#230000",
		"statusBar.foreground": "#7f8f9b",
		"statusBar.noFolderBackground": "#1c1f26",
		"statusBarItem.remoteBackground": "#1c1f26",
		"statusBarItem.remoteForeground": "#7f8f9b"
	},
	"breadcrumbs.enabled": false,
	"editor.fontFamily": "'Lucida Console', Menlo, Monaco, 'Courier New', monospace",
	"editor.fontSize": 14,
	"editor.lineHeight": 16,
	"editor.renderIndentGuides": false,
	"editor.scrollBeyondLastLine": false,
	"editor.tabSize": 4,
	"editor.detectIndentation": true,
	"editor.insertSpaces": false,
	"editor.overviewRulerBorder": false,
	"editor.minimap.enabled": false,
	"explorer.confirmDelete": false,
	"explorer.openEditors.visible": 0,
	"extensions.showRecommendationsOnlyOnDemand": true,
	"extensions.autoUpdate": false,
	"extensions.ignoreRecommendations": true,
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/*.pyc": true,
		"**/__pycache__/": true
	},
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/node_modules/**": true,
		"**/vendor/**": true,
	},
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/vendor": true,
	},
	"files.eol": "\n",
	"git.enabled": false,
	"http.proxy": "http://127.0.0.1:8118",
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.fontFamily": "'Lucida Console', Menlo, Monaco, 'Courier New', monospace",
	"terminal.external.osxExec": "iTerm.app",
	"telemetry.enableTelemetry": false,
	"telemetry.enableCrashReporter": false,
	"typescript.check.npmIsInstalled": false,
	"update.mode": "none",
	"update.showReleaseNotes": false,
	"[c]": {
		"editor.defaultFormatter": "ms-vscode.cpptools",
		"editor.formatOnSave": true
	},
	"[go]": {
		"editor.snippetSuggestions": "none",
		"editor.formatOnSave": true,
		"editor.formatOnSaveTimeout": 3000,
		"editor.codeActionsOnSave": {
			"source.organizeImports": true
		},
		"editor.codeActionsOnSaveTimeout": 3000
	},
	"[python]": {
		"editor.insertSpaces": true,
		"editor.formatOnSave": true
	},
	"[rust]": {
		"editor.formatOnSave": true
	},
	// Extension specific
	"go.lintOnSave": "off",
	"go.buildOnSave": "off",
	"go.vetOnSave": "off",
	"go.formatTool": "goimports",
	"go.useLanguageServer": true,
	"python.formatting.provider": "black",
	"python.linting.pylintEnabled": false
}