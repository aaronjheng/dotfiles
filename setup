#!/bin/bash
set -e

ROOT=$(
	cd "$(dirname "$0")"
	pwd
)

pushd() {
	command pushd "$@" >/dev/null
}

popd() {
	command popd "$@" >/dev/null
}

sync_files() {
	rsync -aq --exclude-from=rsyncexclude . ~
}

install() {
	_ensure_sudo_no_password

	_install_homebrew

	_install_formulas

	_install_z

	_install_loopback_alias

	_install_vundle

	sync_files
}

_ensure_sudo_no_password() {
	echo "%admin ALL=(ALL) NOPASSWD: ALL" | sudo tee /etc/sudoers.d/admin 1>/dev/null
}

_install_homebrew() {
	ruby -e "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/master/install)"
}

_install_formulas() {
	brew install bash-completion rsync git wget iproute2mac
}

_install_z() {
	curl -fsSL -o ~/.z.sh https://raw.githubusercontent.com/rupa/z/master/z.sh
}

_install_loopback_alias() {
	LOOPBACK_ALIAS=loopback.alias.plist
	pushd /Library/LaunchDaemons
	sudo cp $ROOT/contrib/$LOOPBACK_ALIAS $LOOPBACK_ALIAS
	sudo chmod 0644 $LOOPBACK_ALIAS
	sudo launchctl load $LOOPBACK_ALIAS
	popd
}

_install_vundle() {
	git clone https://github.com/gmarik/Vundle.vim.git ~/.vim/bundle/Vundle.vim
	vim +PluginInstall +qall
}

pushd $ROOT

if [ "$1" = "sync" ]; then
	sync_files
elif [ "$1" = "install" ]; then
	install
else
	echo "Invalid action"
	exit 1
fi

popd
