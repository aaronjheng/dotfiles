{
	"workbench.activityBar.visible": false,
	"workbench.colorTheme": "Spacegray Ocean Dark",
	"workbench.editor.showIcons": false,
	"workbench.iconTheme": null,
	"editor.fontFamily": "'Lucida Console', Menlo, Monaco, 'Courier New', monospace",
	"editor.fontSize": 14,
	"editor.lineHeight": 16,
	"editor.renderIndentGuides": false,
	"editor.scrollBeyondLastLine": false,
	"editor.tabSize": 4,
	"editor.detectIndentation": true,
	"editor.insertSpaces": false,
	"editor.overviewRulerBorder": false,
	"editor.minimap.enabled": false,
	"terminal.integrated.fontSize": 14,
	"terminal.integrated.fontFamily": "'Lucida Console', Menlo, Monaco, 'Courier New', monospace",
	"explorer.openEditors.visible": 0,
	"http.proxy": "http://127.0.0.1:1087",
	"terminal.external.osxExec": "iTerm.app",
	"telemetry.enableTelemetry": false,
	"telemetry.enableCrashReporter": false,
	"git.enabled": false,
	"[python]": {
		"editor.insertSpaces": true
	},
	"workbench.colorCustomizations": {
		"focusBorder": "#63717c",
		"badge.background": "#1c1f26",
		"badge.foreground": "#7f8f9b",
		"editorGroupHeader.tabsBackground": "#232830",
		"editorLineNumber.foreground": "#7f8f9b",
		"editorGroup.border": "#232830",
		"foreground": "#7f8f9b",
		"statusBar.noFolderBackground": "#1c1f26",
		"tab.inactiveBackground": "#232830",
		"tab.inactiveForeground": "#7f8f9b"
	},
	"typescript.check.npmIsInstalled": false,
	"window.zoomLevel": 0,
	"workbench.startupEditor": "newUntitledFile",
	"files.exclude": {
		"**/.git": true,
		"**/.svn": true,
		"**/.hg": true,
		"**/CVS": true,
		"**/.DS_Store": true,
		"**/*.pyc": true,
        "**/__pycache__/": true
	},
	"extensions.autoUpdate": false,
	"extensions.ignoreRecommendations": true,
	
	// Extension specific
	"go.coverOnSave": false,
	"go.lintOnSave": "off",
	"go.vetOnSave": "off",

	"python.pythonPath": "/usr/local/bin/python3",
	"python.formatting.provider": "yapf",
	"python.linting.pylintEnabled": false,
}
