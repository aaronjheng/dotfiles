{
  "$schema": "https://opencode.ai/config.json",
  "model": "volcanoengine/glm-5.1",
  "provider": {
    "volcanoengine": {
      "name": "Volcano Engine",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "apiKey": "{{ get . "volcano_engine_api_key" | default "" }}"
      },
      "models": {
        "deepseek-v3.2": {
          "name": "DeepSeek V3.2",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "glm-5.1": {
          "name": "GLM 5.1",
          "limit": {
            "context": 200000,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "minimax-m2.7": {
          "name": "Minimax M2.7",
          "limit": {
            "context": 204800,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "limit": {
            "context": 262144,
            "output": 98304
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "autoupdate": false
}
