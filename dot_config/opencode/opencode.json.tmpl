{
  "$schema": "https://opencode.ai/config.json",
  "model": "volcanoengine/glm-5.1",
  "provider": {
    "volcanoengine": {
      "name": "Volcano Engine",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://ark.cn-beijing.volces.com/api/coding/v3",
        "apiKey": "{{ get . "volcano_engine_api_key" | default "" }}"
      },
      "models": {
        "glm-5.1": {
          "name": "GLM 5.1",
          "limit": {
            "context": 200000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "limit": {
            "context": 256000,
            "output": 164000
          },
          "modalities": {
            "input": [
              "text",
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "autoupdate": false
}
